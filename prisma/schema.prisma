datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  READY_FOR_PICKUP
  DELIVERED
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  contact   String
  email     String?
  createdAt DateTime @default(now())

  jobs      Job[]
}

model Job {
  id          String    @id @default(cuid())
  description String
  status      JobStatus @default(PENDING)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  trackingCode String?  @unique
  paperSize    String?
  quantity     Int?     @default(1)
  printType    String?
  finishing    String?
  estimatedPrice Float?
  archived       Boolean   @default(false)

  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])

  files       FileUpload[]
  notes       JobNote[]
}

model FileUpload {
  id           String   @id @default(cuid())
  url          String
  originalName String
  fileType     String
  uploadedAt   DateTime @default(now())

  jobId        String
  job          Job      @relation(fields: [jobId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  notes     JobNote[]
}

model JobNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
}

model PricingConfig {
  id            String   @id @default("default")
  
  shortBw       Float    @default(3)
  shortCol      Float    @default(8)
  longBw        Float    @default(4)
  longCol       Float    @default(10)
  a4Bw          Float    @default(4)
  a4Col         Float    @default(10)
  legalBw       Float    @default(5)
  legalCol      Float    @default(12)

  lamination    Float    @default(15)
  bindingComb   Float    @default(50)
  bindingSpiral Float    @default(80)

  updatedAt     DateTime @updatedAt
}

model StoreSettings {
  id                String   @id @default("default")

  // Manual override
  isAcceptingOrders Boolean  @default(true)
  closedMessage     String   @default("We are currently closed and not accepting new print jobs at this time. Please check back later!")

  // Automatic schedule
  scheduleEnabled   Boolean  @default(false)
  openTime          String   @default("08:00")   // 24-hr format e.g. "08:00"
  closeTime         String   @default("17:00")
  openDays          String   @default("MON,TUE,WED,THU,FRI") // comma-separated

  updatedAt         DateTime @updatedAt
}
